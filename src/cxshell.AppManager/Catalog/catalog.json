      "name": "Files",
      "summary": "Explorer-style terminal file manager",
      "descriptionHtml": "<h2>Files (cxfiles)</h2><p>A polished, Windows-Explorer-style file manager for the terminal: three-pane layout with folder tree, file list and detail panel; tabs; full file operations with background progress; a tabbed Properties dialog with live disk-usage; trash support; context menus and keyboard-driven navigation.</p>",
      "icon": "",
      "logo": "https://raw.githubusercontent.com/nickprotop/cxfiles/master/.github/logo.svg",
      "categories": ["System", "FileManager", "Utility"],
      "group": "Applications",
      "order": 10,
      "homepage": "https://github.com/nickprotop/cxfiles",
      "sources": [
        { "kind": "binary", "label": "Prebuilt binary",
          "uri": "binary+github-release:nickprotop/cxfiles?asset=cxfiles-linux-{arch}" },
        { "kind": "source", "label": "Build from source",
          "uri": "source+git:https://github.com/nickprotop/cxfiles?ref=master",
          "build": { "steps": [ { "run": "dotnet publish cxfiles/cxfiles.csproj -c Release -o out --self-contained -r linux-{arch}" } ], "artifact": "out", "exe": "cxfiles", "net": true } }
      ]
    },
